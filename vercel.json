{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "static/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/" },
    { "src": "/static/(.*)", "dest": "/static/" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
